# YouTube Automation System - Environment Variables
# Copy this file to .env and fill in your values

# === REQUIRED ===
# OpenAI API key for script generation and SEO optimization
OPENAI_API_KEY=sk-your-openai-key-here

# ElevenLabs API key for AI voiceover generation
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# === YOUTUBE API (Required for upload automation) ===
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=your-client-id
YOUTUBE_CLIENT_SECRET=your-client-secret

# === OPTIONAL ===
# Default ElevenLabs voice ID (find at https://api.elevenlabs.io/v1/voices)
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Channel niche (dark_psychology, stoicism, ai_tech)
CHANNEL_NICHE=dark_psychology

# Content output directory
CONTENT_DIR=./output

# Database URL
DATABASE_URL=sqlite:///./youtube_automation.db

# Web dashboard settings
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# Webhook secret for Make.com/Zapier integrations
WEBHOOK_SECRET=your-webhook-secret

# Social media API keys (optional, for cross-posting)
TIKTOK_SESSION_ID=
INSTAGRAM_ACCESS_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
