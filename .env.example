# Supabase (apps/web)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Gateway
NEXT_PUBLIC_GATEWAY_URL=
NEXT_PUBLIC_USE_MOCK=true

# Agent services (services/*)
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
AYRSHARE_API_KEY=
CLOUDINARY_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ASI:One LLM (used by Head Agent, Strategist, Critic)
ASI_ONE_API_KEY=
ASI_ONE_BASE_URL=https://api.asi1.ai/v1
ASI_ONE_MODEL=asi1

# Agent seeds (unique per agent — change for production)
HEAD_AGENT_SEED=agentbuffer-head-agent-seed-v1
STRATEGIST_SEED=agentbuffer-strategist-seed-v1
CRITIC_SEED=agentbuffer-critic-seed-v1
VIDEO_CREATOR_SEED=agentbuffer-video-creator-seed-v1
PUBLISHER_SEED=agentbuffer-publisher-seed-v1

# Agent ports
HEAD_AGENT_PORT=8001
STRATEGIST_PORT=8002
CRITIC_PORT=8003
VIDEO_CREATOR_PORT=8004
PUBLISHER_PORT=8005

# Agent addresses (fill after Agentverse registration)
STRATEGIST_ADDRESS=
CRITIC_ADDRESS=
VIDEO_CREATOR_ADDRESS=
PUBLISHER_ADDRESS=

# Calendar feature flags
USE_APPROVAL_QUEUE=true

# Fault injection (services/publisher only)
PUBLISHER_FAULT_MODE=
